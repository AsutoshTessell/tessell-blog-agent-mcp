# Copy to `.env` — do NOT commit this file.

# --- Sanity (required) ---
SANITY_PROJECT_ID=krotrzct
SANITY_DATASET=staging
SANITY_TOKEN=        # sanity.io/manage → Tessell project → API → Tokens → Add token (Editor role)

# --- GitHub (required for changelog ingestion) ---
GITHUB_TOKEN=        # github.com/settings/tokens → Tokens (classic) → repo scope
TESSELL_GITHUB_REPOS=https://github.com/TessellDevelopment/tessell-ui,https://github.com/TessellDevelopment/tessell-api-specifications

# --- Hashnode (optional — skip if not syndicating to Hashnode) ---
HASHNODE_ACCESS_TOKEN=      # hashnode.com → Account Settings → Developer → Personal Access Tokens
HASHNODE_PUBLICATION_HOST=  # e.g. yourname.hashnode.dev
HASHNODE_PUBLICATION_ID=    
HASHNODE_PUBLISH_MODE=draft # draft (default) or publish

# Only set if the same post is published on both tessell.com AND Hashnode (for SEO canonical).
# If Hashnode is your only blog, leave this out.
# TESSELL_BLOG_CANONICAL_BASE_URL=https://www.tessell.com/blog
