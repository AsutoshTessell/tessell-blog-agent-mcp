# Same variables as tessell-web/tessell-website (see sanity/lib/client.tsx).
# Copy this file to `.env` and fill in values. Do not commit `.env`.

SANITY_PROJECT_ID=
SANITY_DATASET=staging
SANITY_TOKEN=

# Read-only (optional): for get_published_blogs / GROQ fetch. Can be SANITY_READ_TOKEN in some setups.
# SANITY_TOKEN=

# For publish_blog_to_sanity you must set SANITY_TOKEN to a write-capable token (Editor or token with mutate scope).
# Same variable as tessell-website if that env already uses a write token locally.
