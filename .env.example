# Copy to `.env` in this repo. Do not commit `.env`.
# Used only by tessell-blog-agent-mcp (see `src/loadEnv.ts`).

SANITY_PROJECT_ID=
SANITY_DATASET=staging
SANITY_TOKEN=

# Read-only (optional): for GROQ fetch; some setups use SANITY_READ_TOKEN instead.
# For publish_blog_to_sanity use a write-capable token (mutate / assets).

# Optional blogPost defaults if drafts omit frontmatter (Vision: blogCategory / blogTag _id values):
# TESSELL_DEFAULT_BLOG_CATEGORY_REF=
# TESSELL_DEFAULT_BLOG_TAG_REFS=id1,id2

# Optional workflow paths (see README):
# TESSELL_UI_REPO=/absolute/path/to/tessell-ui
# TESSELL_BLOG_DAYS_BACK=15
# TESSELL_BLOG_DRAFTS_DIR=
