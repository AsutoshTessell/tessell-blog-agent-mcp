# Copy to `.env` in this repo. Do not commit `.env`.
# Used only by tessell-blog-agent-mcp (see `src/loadEnv.ts`).

SANITY_PROJECT_ID=
SANITY_DATASET=staging
SANITY_TOKEN=

# Read-only (optional): for GROQ fetch; some setups use SANITY_READ_TOKEN instead.
# For publish_blog_to_sanity use a write-capable token (mutate / assets).
#
# Category & tags: markdown_to_sanity_blog fetches live blogCategory/blogTag from Sanity
# and matches frontmatter (see README). TESSELL_DEFAULT_BLOG_* is not used for taxonomy.

# Optional workflow paths (see README):
# TESSELL_UI_REPO=/absolute/path/to/tessell-ui
# TESSELL_BLOG_DAYS_BACK=15
# TESSELL_BLOG_DRAFTS_DIR=

# Multi-repo changelog (tool: read_tessell_github_product_changelog) — shallow-clones into .data/git-cache by default
# Comma- or newline-separated GitHub URLs (https://github.com/org/repo or git@github.com:org/repo.git)
# TESSELL_GITHUB_REPOS=https://github.com/TessellDevelopment/tessell-ui,https://github.com/TessellDevelopment/tessell-api-specifications
# Fine-grained PAT with read access to those repos (private). Not stored in git remote URLs — passed per git invocation.
# GITHUB_TOKEN=
# Optional: override clone cache directory (default: <mcp-repo>/.data/git-cache)
# TESSELL_GIT_CACHE_DIR=
# Optional: max repos to process after dedupe (default 20, cap 100)
# TESSELL_GITHUB_MAX_REPOS=20
